{
    "name": "ai-interview-simulator",
    "version": "1.0.0",
    "description": "AI-powered live coding interview simulator with Gemini Live API integration",
    "main": "dist/server/index.js",
    "scripts": {
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "dev:backend": "tsx watch src/server/index.ts",
        "dev:frontend": "cd frontend && npm run dev",
        "build": "npm run build:backend && npm run build:frontend",
        "build:backend": "tsc -p tsconfig.json",
        "build:frontend": "cd frontend && npm run build",
        "start": "node dist/server/index.js",
        "lint": "eslint src/**/*.{ts,tsx}",
        "test": "jest"
    },
    "keywords": [
        "ai",
        "interview",
        "simulator",
        "gemini",
        "vertex-ai"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "express": "^4.18.2",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "google-auth-library": "^9.4.1",
        "ws": "^8.16.0",
        "uuid": "^9.0.1",
        "zod": "^3.22.4",
        "axios": "^1.6.2",
        "multer": "^1.4.5-lts.1"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/cors": "^2.8.17",
        "@types/node": "^20.10.5",
        "@types/ws": "^8.5.10",
        "@types/uuid": "^9.0.7",
        "@types/multer": "^1.4.11",
        "@typescript-eslint/eslint-plugin": "^6.15.0",
        "@typescript-eslint/parser": "^6.15.0",
        "concurrently": "^8.2.2",
        "eslint": "^8.56.0",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3"
    }
}